
@using TarvelAI.DTOs.AI
@inject HttpClient Http

<PageTitle>AI Planner – TravelAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-12">
    <MudStack Spacing="2" Class="mb-8">
        <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a2b4a;">
            AI Travel Planner
        </MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Answer a few questions and get a personalized travel recommendation!
        </MudText>
    </MudStack>

    <MudStepper @bind-ActiveStep="_step">
        <MudStep Label="Weather">
            <MudSelect @bind-Value="_prefs.Weather" Label="Preferred Weather" Required="true">
                <MudSelectItem Value="Warm">Warm</MudSelectItem>
                <MudSelectItem Value="Mild">Mild</MudSelectItem>
                <MudSelectItem Value="Cold">Cold</MudSelectItem>
                <MudSelectItem Value="Any">Any</MudSelectItem>
            </MudSelect>
        </MudStep>
        <MudStep Label="Location Type">
            <MudRadioGroup @bind-SelectedOption="_prefs.LocationType">
                <MudRadio Option="City"    Label="City" />
                <MudRadio Option="Village" Label="Village" />
                <MudRadio Option="Any"     Label="Any" />
            </MudRadioGroup>
        </MudStep>
        <MudStep Label="Budget">
            <MudNumericField @bind-Value="_prefs.Budget" Label="Budget ($)" Min="0" Required="true" />
        </MudStep>
        <MudStep Label="Destination Type">
            <MudSelect @bind-Value="_prefs.DestinationType" Label="Destination Type" Required="true">
                <MudSelectItem Value="Beach">Beach</MudSelectItem>
                <MudSelectItem Value="Mountain">Mountain</MudSelectItem>
                <MudSelectItem Value="City Break">City Break</MudSelectItem>
                <MudSelectItem Value="Countryside">Countryside</MudSelectItem>
                <MudSelectItem Value="Any">Any</MudSelectItem>
            </MudSelect>
        </MudStep>
        <MudStep Label="Dates">
            <MudDateRangePicker @bind-DateRange="_dateRange" Label="Travel Dates" Required="true" />
        </MudStep>
        <MudStep Label="Review & Submit">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GetRecommendation" Disabled="_loading">
                Get Recommendation
            </MudButton>
        </MudStep>
    </MudStepper>

    @if (_recommendation != null)
    {
        <MudPaper Class="mt-6 pa-4">
            <MudText Typo="Typo.h6">AI Recommendation:</MudText>
            <MudText>@_recommendation</MudText>
        </MudPaper>
    }
    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" Class="mt-4" />
    }
</MudContainer>

@code {
    private int _step = 0;
    private ConversationPreferences _prefs = new();
    private MudBlazor.DateRange _dateRange = new();
    private string? _recommendation;
    private bool _loading = false;

    private async Task GetRecommendation()
    {
        _prefs.StartDate = _dateRange.Start;
        _prefs.EndDate = _dateRange.End;
        _loading = true;

        // Build conversation as expected by backend
        var conversation = new List<ConversationTurn>
        {
            new() { Role = "User", Text = _prefs.Weather ?? "" },
            new() { Role = "User", Text = _prefs.LocationType ?? "" },
            new() { Role = "User", Text = _prefs.Budget?.ToString() ?? "" },
            new() { Role = "User", Text = _prefs.DestinationType ?? "" },
            new() { Role = "User", Text = $"{_prefs.StartDate:yyyy-MM-dd} to {_prefs.EndDate:yyyy-MM-dd}" }
        };

        var response = await Http.PostAsJsonAsync("/api/ai/converse", conversation);
        var aiTurn = await response.Content.ReadFromJsonAsync<ConversationTurn>();
        _recommendation = aiTurn?.Text;
        _loading = false;
    }
}


