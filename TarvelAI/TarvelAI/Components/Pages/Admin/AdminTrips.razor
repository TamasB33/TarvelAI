@page "/admin/trips"
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using TarvelAI.DTOs.Trip
@using TarvelAI.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Admin - Trips</PageTitle>

<MudStack Row AlignItems="AlignItems.Center" Class="mb-6">
    <MudText Typo="Typo.h4" Style="font-weight:700;">Trips</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateDialog">
        Add Trip
    </MudButton>
</MudStack>

@if (_trips is null)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" />
}
else
{
    <MudTable Items="_trips" Hover Striped Elevation="2" Style="border-radius:12px;">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Destination</MudTh>
            <MudTh>Duration</MudTh>
            <MudTh>Price</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Destination</MudTd>
            <MudTd>@context.DurationDays days</MudTd>
            <MudTd>$@context.BasePrice.ToString("N2")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                               OnClick="() => OpenEditDialog(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               OnClick="() => DeleteTrip(context.Id)" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* Create / Edit Dialog *@
<MudDialog @bind-Visible="_dialogOpen">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingId is null ? "Add Trip" : "Edit Trip")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_form.Name"        Label="Name"        Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_form.Destination" Label="Destination" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_form.Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
            <MudTextField @bind-Value="_form.ImageUrl"    Label="Image URL"   Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="_form.BasePrice"    Label="Base Price ($)" Variant="Variant.Outlined" Min="0" Step="0.01m" />
            <MudNumericField @bind-Value="_form.DurationDays" Label="Duration (days)" Variant="Variant.Outlined" Min="1" Max="365" />
            <MudSelect @bind-Value="_form.Status" Label="Status" Variant="Variant.Outlined">
                @foreach (TripStatus s in Enum.GetValues(typeof(TripStatus)))
                {
                    <MudSelectItem Value="s">@s</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogOpen = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTrip">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<TripDto>?  _trips;
    private bool            _dialogOpen;
    private int?            _editingId;
    private string          _adminUserId = "";

    private CreateTripDto _form = new() { Name = "", Destination = "", CreatedBy = "" };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _adminUserId  = authState.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        await LoadTrips();
    }

    private async Task LoadTrips()
        => _trips = await Http.GetFromJsonAsync<List<TripDto>>("/api/trips");

    private void OpenCreateDialog()
    {
        _editingId  = null;
        _form       = new CreateTripDto { Name = "", Destination = "", CreatedBy = _adminUserId };
        _dialogOpen = true;
    }

    private void OpenEditDialog(TripDto trip)
    {
        _editingId = trip.Id;
        _form = new CreateTripDto
        {
            Name         = trip.Name,
            Destination  = trip.Destination,
            Description  = trip.Description,
            ImageUrl     = trip.ImageUrl,
            BasePrice    = trip.BasePrice,
            DurationDays = trip.DurationDays,
            Status       = trip.Status,
            CreatedBy    = trip.CreatedBy
        };
        _dialogOpen = true;
    }

    private async Task SaveTrip()
    {
        HttpResponseMessage response;

        if (_editingId is null)
        {
            _form.CreatedBy = _adminUserId;
            response = await Http.PostAsJsonAsync("/api/trips", _form);
        }
        else
        {
            var update = new UpdateTripDto
            {
                Name         = _form.Name,
                Destination  = _form.Destination,
                Description  = _form.Description,
                ImageUrl     = _form.ImageUrl,
                BasePrice    = _form.BasePrice,
                DurationDays = _form.DurationDays,
                Status       = _form.Status
            };
            response = await Http.PutAsJsonAsync($"/api/trips/{_editingId}", update);
        }

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(_editingId is null ? "Trip created." : "Trip updated.", Severity.Success);
            _dialogOpen = false;
            await LoadTrips();
        }
        else
        {
            Snackbar.Add("Something went wrong.", Severity.Error);
        }
    }

    private async Task DeleteTrip(int id)
    {
        var response = await Http.DeleteAsync($"/api/trips/{id}");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Trip deleted.", Severity.Success);
            await LoadTrips();
        }
        else
        {
            Snackbar.Add("Something went wrong.", Severity.Error);
        }
    }

    private static Color StatusColor(TripStatus status) => status switch
    {
        TripStatus.Planning   => Color.Default,
        TripStatus.Confirmed  => Color.Primary,
        TripStatus.Completed  => Color.Success,
        TripStatus.Cancelled  => Color.Error,
        _                     => Color.Default
    };
}
