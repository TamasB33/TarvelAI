@using TarvelAI.DTOs.Trip
@using TarvelAI.Models

<MudDialog MaxWidth="false" FullWidth="true" Style="width:1200px;max-width:98vw;">
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Form.Name"        Label="Name"        Variant="Variant.Outlined" />
            <MudTextField @bind-Value="Form.Destination" Label="Destination" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="Form.Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
            <MudTextField @bind-Value="Form.ImageUrl"    Label="Image URL"   Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="Form.BasePrice"    Label="Base Price ($)"  Variant="Variant.Outlined" Min="0" Step="0.01m" />
            <MudNumericField @bind-Value="Form.DurationDays" Label="Duration (days)" Variant="Variant.Outlined" Min="1" Max="365" />
            <MudSelect @bind-Value="Form.Status" Label="Status" Variant="Variant.Outlined">
                @foreach (TripStatus s in Enum.GetValues(typeof(TripStatus)))
                {
                    <MudSelectItem Value="s">@s</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Title { get; set; } = "Trip";
    [Parameter] public CreateTripDto Form { get; set; } = new() { Name = "", Destination = "", CreatedBy = "" };

    void Cancel() => MudDialog.Cancel();
    void Submit() => MudDialog.Close(DialogResult.Ok(Form));
}
