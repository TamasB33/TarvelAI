<MudContainer MaxWidth="MaxWidth.False" Style="background: #f8fafc; border-top: 1px solid #e2e8f0; padding: 48px 24px 24px;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudGrid Spacing="6">
            <MudItem xs="12" sm="3">
                <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1a2b4a; font-style: italic;" Class="mb-2">
                    TravelAI
                </MudText>
                <MudText Typo="Typo.body2" Style="color: #5a6a7a;">
                    Transforming the architecture of travel through intelligence and curation.
                </MudText>
            </MudItem>

            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.overline" Style="font-weight: 700; color: #1a2b4a; letter-spacing: 2px;" Class="mb-3">
                    PLATFORM
                </MudText>
                <MudStack Spacing="1">
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">AI Planner</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Curated Stays</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Flights</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Experiences</MudLink>
                </MudStack>
            </MudItem>
                
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.overline" Style="font-weight: 700; color: #1a2b4a; letter-spacing: 2px;" Class="mb-3">
                    COMPANY
                </MudText>
                <MudStack Spacing="1">
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">About Us</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Careers</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Privacy Policy</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Terms of Service</MudLink>
                </MudStack>
            </MudItem>

            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.overline" Style="font-weight: 700; color: #1a2b4a; letter-spacing: 2px;" Class="mb-3">
                    CONNECT
                </MudText>
                <MudStack Spacing="1">
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Contact</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Newsletter</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Twitter</MudLink>
                    <MudLink Typo="Typo.body2" Color="Color.Default" Style="color: #5a6a7a;">Instagram</MudLink>
                </MudStack>
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-6" />

        <MudText Typo="Typo.caption" Style="color: #94a3b8;">
            © 2026 TravelAI. The Curated Horizon.
        </MudText>
    </MudContainer>
</MudContainer>
