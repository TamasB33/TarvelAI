<MudContainer MaxWidth="MaxWidth.False" Style="background: #f1f5f9; padding: 64px 24px;">
    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="mb-10">
        <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 700; color: #1a2b4a; font-style: italic;">
            Your Journey in Three Beats
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Style="color: #5a6a7a;">
            Sophisticated travel planning simplified into a single conversation.
        </MudText>
    </MudStack>

    <MudGrid Justify="Justify.Center" Spacing="6">
        <MudItem xs="12" sm="4">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Size="Size.Large" Style="background: #d1ecf9; color: #1a2b4a;">
                    <MudIcon Icon="@Icons.Material.Filled.Chat" />
                </MudAvatar>
                <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight: 700; color: #1a2b4a;">
                    Talk to AI
                </MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Style="color: #5a6a7a;">
                    Tell us your wildest travel dreams in plain English. No complex filters, just natural human language.
                </MudText>
            </MudStack>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Size="Size.Large" Style="background: #dbeafe; color: #1a2b4a;">
                    <MudIcon Icon="@Icons.Material.Filled.Dashboard" />
                </MudAvatar>
                <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight: 700; color: #1a2b4a;">
                    Personalize your Canvas
                </MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Style="color: #5a6a7a;">
                    Watch as our AI builds a visual board of flights, stays, and hidden gems tailored uniquely to your profile.
                </MudText>
            </MudStack>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Size="Size.Large" Style="background: #e2e8f0; color: #1a2b4a;">
                    <MudIcon Icon="@Icons.Material.Filled.TouchApp" />
                </MudAvatar>
                <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight: 700; color: #1a2b4a;">
                    Book with One Click
                </MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Style="color: #5a6a7a;">
                    Happy with the curation? Secure your entire itinerary, including private transfers and exclusive tables, in seconds.
                </MudText>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>
