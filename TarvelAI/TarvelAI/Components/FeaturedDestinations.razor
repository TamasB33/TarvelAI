<MudContainer MaxWidth="MaxWidth.Large" Class="py-12">
    <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a2b4a;">
        Featured AI-Curated Destinations
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        Our neural networks have analyzed millions of reviews, weather patterns, and flight costs to find the perfect escape for you.
    </MudText>

    <MudGrid Spacing="4">
        @for (int i = 0; i < Destinations.Count; i++)
        {
            var dest = Destinations[i];
            var isLarge = i == 0;
            var isWide = i == Destinations.Count - 1;

            <MudItem xs="12" sm="@(isLarge ? 4 : isWide ? 8 : 4)" md="@(isLarge ? 4 : isWide ? 8 : 4)"
                     Class="@(isLarge ? "dest-card-large" : "")">
                <MudCard Class="dest-card" Elevation="4" Style="height: 100%;">
                    <MudContainer MaxWidth="MaxWidth.False" Style="position: relative; height: 100%; padding: 0;">
                        <MudImage Src="@dest.ImageUrl" Alt="@dest.Title"
                                  ObjectFit="ObjectFit.Cover"
                                  Class="dest-card-img" />
                        <MudOverlay Visible="true" Absolute="true" DarkBackground="false" Class="dest-card-gradient">
                            <MudStack Justify="Justify.FlexEnd" Class="pa-4" Style="height: 100%;">
                                @if (isLarge)
                                {
                                    <MudChip T="string" Size="Size.Small"
                                             Style="background: rgba(255,255,255,0.2); backdrop-filter: blur(4px); color: #fff; font-weight: 700; letter-spacing: 1px;">
                                        AI RECOMMENDATION
                                    </MudChip>
                                }
                                <MudText Typo="Typo.h6" Style="color: #fff; font-weight: 700;">@dest.Title</MudText>
                                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.85);">@dest.Description</MudText>
                            </MudStack>
                        </MudOverlay>
                    </MudContainer>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

<style>
    .dest-card {
        border-radius: 16px !important;
        overflow: hidden;
        min-height: 220px;
    }

    .dest-card-large .dest-card {
        min-height: 460px;
    }

    .dest-card-large {
        grid-row: span 2;
    }

    .dest-card-img {
        width: 100%;
        height: 100%;
        display: block;
    }

    .dest-card-gradient {
        background: linear-gradient(to top, rgba(0,0,0,0.7), transparent) !important;
    }
</style>

@code {
    private record Destination(string Title, string Description, string ImageUrl);

    private List<Destination> Destinations { get; set; } = [];

    private static readonly (string Title, string Description, string Query)[] DestinationPool =
    [
        ("Kyoto Modernism", "A blend of ancient shrines and minimalist boutique hotels curated for the thoughtful traveler.", "kyoto+temple"),
        ("Reykjavik Rim", "Extreme luxury in Iceland.", "iceland+landscape"),
        ("Amalfi Drift", "Coastal secrets revealed.", "amalfi+coast"),
        ("Serengeti Pulse", "Ethical safari experiences mapped by AI.", "serengeti+safari"),
        ("Santorini Glow", "Sunset views over the caldera.", "santorini+sunset"),
        ("Patagonia Wild", "Untamed beauty at the edge of the world.", "patagonia+mountains"),
        ("Bali Serenity", "Tropical wellness retreats.", "bali+rice+terrace"),
        ("Swiss Alpine", "Peaks and charm in the heart of Europe.", "swiss+alps"),
        ("Marrakech Mosaic", "Vibrant markets and hidden riads.", "marrakech+market"),
        ("Banff Majesty", "Crystal lakes and towering Rockies.", "banff+lake"),
        ("Maldives Drift", "Overwater luxury in turquoise paradise.", "maldives+ocean"),
        ("Cape Town Edge", "Where mountains meet the sea.", "cape+town+mountain"),
    ];

    protected override void OnInitialized()
    {
        var rng = Random.Shared;
        var indices = Enumerable.Range(0, DestinationPool.Length)
            .OrderBy(_ => rng.Next())
            .Take(4)
            .ToList();

        Destinations = indices.Select(i =>
        {
            var d = DestinationPool[i];
            var imageUrl = $"https://picsum.photos/seed/{d.Query}-{rng.Next(10000)}/800/600";
            return new Destination(d.Title, d.Description, imageUrl);
        }).ToList();
    }
}
