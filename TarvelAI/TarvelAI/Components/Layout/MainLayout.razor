@using MudBlazor
@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <TopNavBar />
    <MudMainContent>
        @Body
    </MudMainContent>   
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#00539C",
            Secondary = "#008B8B",
            Tertiary = "#F0F8FF",
            Background = "#F8FAFC",
            AppbarBackground = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            Surface = "#FFFFFF",
            TextPrimary = "#212121",
            TextSecondary = "#757575",
            ActionDefault = "#00539C",
            ActionDisabled = "#9E9E9E",
            Info = "#00539C",
            Success = "#4CAF50",
            Warning = "#FF9800",
            Error = "#F44336"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#00539C",
            Secondary = "#008B8B",
            Tertiary = "#F0F8FF",
            Background = "#1A1A1A",
            AppbarBackground = "#00539C",
            DrawerBackground = "#2D2D2D",
            Surface = "#2D2D2D",
            TextPrimary = "#FFFFFF",
            TextSecondary = "#B0B0B0",
            ActionDefault = "#00539C",
            ActionDisabled = "#6E6E6E",
            Info = "#00539C",
            Success = "#4CAF50",
            Warning = "#FF9800",
            Error = "#F44336"
        }
    };
}
