{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Blazor Server: Launch TarvelAI",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build TarvelAI server",
      "program": "${workspaceFolder}/TarvelAI/TarvelAI/bin/Debug/net10.0/TarvelAI.dll",
      "args": [],
      "cwd": "${workspaceFolder}/TarvelAI/TarvelAI",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
